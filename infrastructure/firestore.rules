rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SYSTEM_ADMIN' ||
          (request.auth.token.email == "navaneeth.j08@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidSession(data) {
      return data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.userId == request.auth.uid &&
             data.lastUpdated is string;
    }

    function isValidMessage(data) {
      return data.role in ['user', 'model'] &&
             data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             data.timestamp is string &&
             data.sessionId is string &&
             data.userId == request.auth.uid;
    }

    function isValidTicket(data) {
      return data.id is string &&
             data.userId is string &&
             data.userMessage is string && data.userMessage.size() > 0 && data.userMessage.size() < 5000 &&
             data.timestamp is string &&
             data.status in ['OPEN', 'IN_PROGRESS', 'RESOLVED'];
    }

    function isValidAuditLog(data) {
      return data.id is string &&
             data.timestamp is string &&
             data.action is string &&
             data.userId is string &&
             data.userRole is string;
    }

    function isValidFeedback(data) {
      return data.id is string &&
             data.deploymentId is string &&
             data.feedback is string && data.feedback.size() > 0 && data.feedback.size() < 2000 &&
             data.userId is string &&
             data.timestamp is string;
    }

    function isValidApproval(data) {
      return data.id is string &&
             data.deploymentId is string &&
             data.planContent is string &&
             data.requestedBy is string &&
             data.timestamp is string &&
             data.status in ['PENDING', 'APPROVED', 'REJECTED'];
    }

    function isValidNotification(data) {
      return data.id is string &&
             data.type is string &&
             data.title is string &&
             data.message is string &&
             data.timestamp is string &&
             data.read is bool &&
             data.severity in ['MINOR', 'MAJOR', 'CRITICAL'];
    }

    // ===============================================================
    // Collections
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /chat_sessions/{sessionId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidSession(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidSession(request.resource.data);
      allow delete: if isOwner(resource.data.userId);

      match /messages/{messageId} {
        allow read: if isOwner(get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data.userId);
        allow create: if isAuthenticated() && isValidMessage(request.resource.data);
        allow update: if false; // Messages are immutable
        allow delete: if isOwner(get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data.userId);
      }
    }

    match /tickets/{ticketId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidTicket(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidAuditLog(request.resource.data);
      allow update: if false;
      allow delete: if false;
    }

    match /feedbacks/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidFeedback(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /approvals/{approvalId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAdmin();
      allow update: if isOwner(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
